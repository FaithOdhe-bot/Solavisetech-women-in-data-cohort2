shopping_list = []

while True:
    print("""
--- SHOPPING LIST MANAGER ---
1. View List  | 2. Add Item  | 3. Remove Item  | 4. Clear List  | 5. Exit
------------------------------------------------------------------------""")
    choice = input("Select an option (1-5): ")

    if choice == "1":
        if not shopping_list:
            print("Your list is empty!")
        else:
            print("\nCurrent Shopping List:")
            for index, item in enumerate(shopping_list, start=1):
                print(f" {index}. {item}")

    elif choice == "2":
        item = input("Enter item to add: ")
        if item:
            shopping_list.append(item)
            print(f"Added '{item}'")

    elif choice == "3":
        item = input("Enter item to remove: ")
        if item in shopping_list:
            shopping_list.remove(item)
            print(f"Removed '{item}'")
        else:
            print(f"'{item}' not found!")

    elif choice == "4":
        shopping_list.clear()
        print("List fully cleared!")

    elif choice == "5":
        print(f"Saving list. Final items: {shopping_list}\nGoodbye!")
        break

    else:
        print("Invalid choice! Please select 1-5.")

capitals_registry = [
    ("United States", "Washington, D.C."),
    ("France", "Paris"),
    ("Canada", "Ottawa"),
    ("United Kingdom", "London"),
    ("Japan", "Tokyo")
]

print("Registered Country-Capital Data Layers:")
print(capitals_registry)
print("-----------------------------------------------------------------")

search_country = input("Enter a country to find its capital: ")

found = False
for country, capital in capitals_registry:
    if country.lower() == search_country.lower():
        print(f"Match Found!")
        print(f"The capital city of {country} is: {capital}")
        found = True
        break
if not found:
    print(f"Search Error: '{search_country}' is not registered in this dataset.")

