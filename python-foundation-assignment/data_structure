scores_list = [78, 92, 85, 64, 99, 71, 88, 93]

print(f"Analyzing Dataset: {scores_list}")
print(f"Total Number of Students: {len(scores_list)}")
print("--------------------------------------------------------------")


highest_score = max(scores_list)
lowest_score = min(scores_list)

